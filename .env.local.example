# VoxChain Environment Variables
# Copy this file to .env.local and fill in your values

# ──────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────

# Gemini 2.0 Flash for AI civic Q&A
GEMINI_API_KEY=your_gemini_api_key

# JWT secret for wallet authentication sessions
JWT_SECRET=your_jwt_secret

# ──────────────────────────────────────────────
# GOOGLE CLOUD APIs (Optional — graceful fallback)
# ──────────────────────────────────────────────

# Google Cloud Translation API v2 — multilingual support
GOOGLE_TRANSLATE_API_KEY=your_translate_api_key

# Google Cloud Text-to-Speech API — read-aloud accessibility
GOOGLE_TTS_API_KEY=your_tts_api_key

# Google Maps Embed API — constituency visualization
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_api_key

# ──────────────────────────────────────────────
# FIREBASE (Optional — graceful fallback)
# ──────────────────────────────────────────────

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
